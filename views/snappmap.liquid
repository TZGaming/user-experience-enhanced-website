{% render 'partials/head.liquid', title: 'SnappThis Homepage' %}

  <main>
    {% render 'partials/topbar.liquid', snapmap: snapmap %}

    <article class="group-name">
      <img src="/assets/svg/group_blue.svg" width="30px" height="30px">
      <h1>{{ groupName }}</h1> 
    </article>

    <div id="successPopup" class="popup-overlay" style="display: none;">
      <div class="popup-content">
        <h2>Your snapp has been added successfully!</h2>
        <button id="successPopupButton" onclick="closePopup()">
          <p>OK</p>
        </button>
      </div>
    </div>

    <article class="camera-button-container">
      <form method="POST" action="/snappmaps/{{ snapmap.uuid }}" enctype="multipart/form-data">
        <label for="picture">
          <img src="/assets/svg/camera.svg" width="60px" height="60px">
          <input type="file" id="picture" name="file" accept="image/*" capture="environment">
        </label>
      </form>
    </article>

    <ul class="photo-grid">
      {% for item in snappmaps %}
      {% assign sorted_snaps = item.snaps | sort: "date_created" | reverse %}
        {% for snap in sorted_snaps %}
          {% if snap.picture.id != null %}
            <li>
              <a href="/snapps/snappmap/{{ snap.uuid }}">
                <img 
                  type="image/webp" 
                  src="https://fdnd-agency.directus.app/assets/{{ snap.picture.id }}?width=200&format=webp" 
                  loading="lazy">
              </a>
            </li>
          {% endif %}
        {% endfor %}
      {% endfor %}
    </ul>

    {% render 'partials/bottombar.liquid' %}
  </main>
</body>

<script>
  const successPopup = document.getElementById('successPopup')
  const successPopupText = document.querySelector('#successPopup h2')
  const successPopupButton = document.getElementById('successPopupButton')
  const successPopupIcon = document.createElement('img')

  window.addEventListener('load', () => {
    const urlParams = new URLSearchParams(window.location.search);
    
    // Als 'success' in de URL staat, toon de popup
    if (urlParams.get('success') === 'true') {
      successPopup.style.display = 'flex';
      if (successPopupText) {
        successPopupText.textContent = "Your snapp has been added successfully!";
      }
      if (successPopupButton) {
        successPopupButton.style.display = 'flex';
      }
      successPopupIcon.remove();
    }
  });

  // Functie om de popup te sluiten
  function closePopup() {
    successPopup.style.display = 'none';
    
    const newUrl = window.location.pathname;
    window.history.replaceState({}, document.title, newUrl);
  }

  const snappUploadForm = document.querySelector("form")
  const fileInput = document.getElementById("picture")
  const photoGrid = document.querySelector(".photo-grid")

  async function refreshPhotoGrid() {
    if (!photoGrid) {
      return;
    }

    try {
      const pageResponse = await fetch(window.location.href);
      const pageText = await pageResponse.text();
      const parser = new DOMParser();
      const pageDoc = parser.parseFromString(pageText, 'text/html');
      const newGrid = pageDoc.querySelector('.photo-grid');
      if (newGrid) {
        photoGrid.innerHTML = newGrid.innerHTML;
      }
    } catch (err) {
      // als refresh faalt, behoudt bestaande grid dan
    }
  }

  // Wanneer een bestand wordt gekozen, submit het form (triggert submit event)
  fileInput.addEventListener("change", function() {
    snappUploadForm.dispatchEvent(new Event('submit'));
  });

  // Als er op de submit button wordt geklikt ...
  snappUploadForm.addEventListener("submit", async function(event) {
    // Voorkom de standaard submit van de browser
    event.preventDefault()
    
    // Loading state tonen met icoon
    successPopup.style.display = 'flex';
    if (successPopupButton) {
      successPopupButton.style.display = 'none';
    }
    
    // Maak loading icoon
    successPopupIcon.src = '/assets/svg/Loading.svg';
    successPopupIcon.width = '50';
    successPopupIcon.height = '50';
    successPopupIcon.style.marginBottom = '15px';
    successPopupIcon.style.animation = 'spin 1s linear infinite';
    
    // Voeg styling toe voor spin animatie
    if (!document.querySelector('#loadingStyle')) {
      const style = document.createElement('style');
      style.id = 'loadingStyle';
      style.textContent = `
        @keyframes spin {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
      `;
      document.head.appendChild(style);
    }
    
    if (successPopupText) {
      successPopupText.textContent = "Uploading...";
      successPopupIcon.remove(); // Verwijder oude icoon als die er is
      successPopupText.parentNode.insertBefore(successPopupIcon, successPopupText);
    }

    // FormData voorbereiden met het bestand
    let formData = new FormData(snappUploadForm);    

    try {
      // Fetch naar de server met FormData (voor multipart/form-data)
      const response = await fetch(snappUploadForm.action, {
        method: snappUploadForm.method, // POST
        body: formData // FormData zorgt automatisch voor multipart/form-data
      })

      const result = await response.json();

      if (response.ok && result.success) {
        // Switch naar success state
        await refreshPhotoGrid();
        if (successPopupButton) {
          successPopupButton.style.display = 'flex';
        }
        successPopupIcon.remove();
        if (successPopupText) {
          successPopupText.textContent = "Your snapp has been added successfully!";
        }
      } else {
        throw new Error(result.message || "Upload failed");
      }

    } catch (err) {
      if (successPopupText) {
        successPopupText.textContent = "Er is een fout opgetreden bij het uploaden: " + err.message;
      }
      if (successPopupButton) {
        successPopupButton.style.display = 'flex';
      }
      successPopupIcon.remove();
    }
  })
</script>